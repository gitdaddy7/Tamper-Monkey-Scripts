// ==UserScript==
// @name         Optics PhoneTool Title
// @namespace    https://optics.amazon.dev/
// @version      2.2.0
// @description  Look up Optics aliases in Phone Tool and show titles inline plus a toggleable summary panel. Press Ctrl+Alt+W to open.
// @match        https://optics.amazon.dev/*
// @include      https://optics.amazon.dev/*
// @run-at       document-end
// @grant        GM_xmlhttpRequest
// @connect      phonetool.amazon.com
// ==/UserScript==

(function () {
  'use strict';

  const PHONE_TOOL_ORIGIN = 'https://phonetool.amazon.com';

  const IDS = {
    style:       'phtt-style',
    toolbar:     'phtt-toolbar',
    panel:       'phtt-panel',
    panelBody:   'phtt-panel-body',
    panelStatus: 'phtt-panel-status',
    panelRows:   'phtt-panel-rows',
  };

  const state = {
    running:      false,
    collapsed:    true,
    aliases:      [],
    results:      new Map(),
    errors:       [],
    hotkeyBound:  false,
  };

  // --- Boot ---
  waitForBody();

  function waitForBody() {
    if (document.body) {
      boot();
    } else {
      document.addEventListener('DOMContentLoaded', boot, { once: true });
    }
  }

  function boot() {
    guardAndInject();
    bindHotkey();
    watchReactRemounts();
    watchSpaNavigation();
  }

  function bindHotkey() {
    if (state.hotkeyBound) return;

    document.addEventListener('keydown', (event) => {
      const key = normalize(event.key).toLowerCase();
      if (!event.ctrlKey || !event.altKey || key !== 'w') return;
      event.preventDefault();
      forceShowUi();
    });

    state.hotkeyBound = true;
  }

  function forceShowUi() {
    if (!isSupportedPage()) return;
    state.collapsed = false;
    guardAndInject();
    renderPanel();
    syncDockPosition();
  }

  function isSupportedPage() {
    return (
      (window.location.pathname.includes('/baselining/') && window.location.pathname.includes('/management')) ||
      window.location.pathname.includes('/access-requests')
    );
  }

  function guardAndInject() {
    if (!isSupportedPage()) return;

    injectStyles();
    ensureToolbar();
    ensurePanel();

    if (!state.aliases.length && !state.running) {
      renderPanel('Ready. Click "Run PhoneTool Title".');
    } else {
      renderPanel();
    }

    syncDockPosition();
  }

  function watchReactRemounts() {
    const observer = new MutationObserver(() => {
      if (!isSupportedPage()) return;

      const toolbarMissing = !document.getElementById(IDS.toolbar);
      const panelMissing   = !document.getElementById(IDS.panel);

      if (toolbarMissing || panelMissing) {
        guardAndInject();
      }

      if (state.results.size > 0) {
        applyInlineResults();
      }
    });

    observer.observe(document.body, { childList: true, subtree: true });
  }

  function watchSpaNavigation() {
    let lastUrl = window.location.href;

    const onNavigate = () => {
      const current = window.location.href;
      if (current !== lastUrl) {
        lastUrl = current;
        state.aliases = [];
        state.results.clear();
        state.errors  = [];
        state.running = false;
        setTimeout(guardAndInject, 600);
      }
    };

    const wrap = (orig) => function (...args) {
      const ret = orig.apply(this, args);
      onNavigate();
      return ret;
    };

    history.pushState    = wrap(history.pushState);
    history.replaceState = wrap(history.replaceState);
    window.addEventListener('popstate', onNavigate);
  }

  function injectStyles() {
    if (document.getElementById(IDS.style)) return;

    const style = document.createElement('style');
    style.id = IDS.style;
    style.textContent = `
      #${IDS.toolbar} {
        position: fixed;
        top: 94px;
        right: 16px;
        z-index: 2147483647;
        display: flex;
        gap: 8px;
        font-family: Arial, Helvetica, sans-serif;
        align-items: center;
        transition: right 160ms ease, top 160ms ease;
      }

      #${IDS.toolbar}.phtt-toolbar-collapsed {
        gap: 0;
      }

      #${IDS.toolbar}.phtt-toolbar-collapsed .phtt-run-btn {
        display: none;
      }

      #${IDS.toolbar}.phtt-toolbar-collapsed .phtt-toggle-btn {
        width: 34px;
        height: 120px;
        padding: 8px 0;
        border-radius: 14px 0 0 14px;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.16);
        writing-mode: vertical-rl;
        text-orientation: mixed;
        transform: none;
        letter-spacing: 0.02em;
        line-height: 1;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
      }

      #${IDS.toolbar}.phtt-toolbar-collapsed .phtt-toggle-btn::after {
        content: '';
        position: absolute;
        top: 0;
        right: -12px;
        width: 12px;
        height: 100%;
      }

      #${IDS.toolbar} button,
      #${IDS.panel} button {
        border: 0;
        border-radius: 999px;
        cursor: pointer;
        font-size: 12px;
        padding: 9px 12px;
      }

      .phtt-run-btn {
        background: #111827;
        color: #fff;
      }

      .phtt-toggle-btn {
        background: #fff;
        color: #111827;
        border: 1px solid #d1d5db;
        position: relative;
        user-select: none;
        touch-action: none;
      }

      .phtt-toggle-grabbing {
        cursor: grabbing !important;
      }

      #${IDS.panel} {
        position: fixed;
        top: 138px;
        right: 16px;
        width: min(380px, calc(100vw - 32px));
        max-height: calc(100vh - 160px);
        z-index: 2147483647;
        border: 1px solid #d1d5db;
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
        overflow: hidden;
        font-family: Arial, Helvetica, sans-serif;
      }

      #${IDS.panel}.phtt-panel-collapsed {
        display: none;
      }

      #${IDS.panel}[data-collapsed="true"] #${IDS.panelBody} {
        display: none;
      }

      .phtt-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 10px 12px;
        background: #111827;
        color: #fff;
      }

      .phtt-title-wrap {
        display: flex;
        flex-direction: column;
        gap: 1px;
      }

      .phtt-title-wrap strong {
        font-size: 13px;
      }

      .phtt-title-wrap span {
        font-size: 11px;
        opacity: 0.82;
      }

      .phtt-panel-header button {
        background: rgba(255, 255, 255, 0.14);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      #${IDS.panelBody} {
        padding: 10px 12px 12px;
      }

      #${IDS.panelStatus} {
        font-size: 12px;
        color: #374151;
        margin-bottom: 8px;
      }

      #${IDS.panelRows} {
        display: flex;
        flex-direction: column;
        gap: 7px;
        max-height: calc(100vh - 260px);
        overflow: auto;
      }

      .phtt-row {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 8px 9px;
        background: #f9fafb;
      }

      .phtt-row.phtt-error {
        background: #fff7ed;
        border-color: #fed7aa;
      }

      .phtt-alias {
        font-size: 12px;
        font-weight: 700;
        color: #111827;
        word-break: break-word;
      }

      .phtt-title {
        font-size: 12px;
        color: #374151;
        text-align: right;
        word-break: break-word;
      }

      .phtt-inline-chip {
        display: inline-flex;
        align-items: center;
        margin-right: 8px;
        padding: 3px 8px;
        border-radius: 999px;
        background: #111827;
        color: #fff;
        font-size: 11px;
        line-height: 1.2;
        white-space: nowrap;
      }

      .phtt-inline-chip.phtt-inline-error {
        background: #b45309;
      }
    `;

    document.head.appendChild(style);
  }

  function ensureToolbar() {
    if (document.getElementById(IDS.toolbar)) return;

    const toolbar = document.createElement('div');
    toolbar.id = IDS.toolbar;

    const runBtn = document.createElement('button');
    runBtn.className   = 'phtt-run-btn';
    runBtn.type        = 'button';
    runBtn.textContent = 'Run PhoneTool Title';
    runBtn.addEventListener('click', () => { void runLookup(); });

    const toggleBtn = document.createElement('button');
    toggleBtn.className   = 'phtt-toggle-btn';
    toggleBtn.type        = 'button';
    toggleBtn.textContent = 'PhoneTool Title';
    toggleBtn.addEventListener('click', () => {
      state.collapsed = !state.collapsed;
      renderPanel();
      syncDockPosition();
    });

    enableVerticalDockDrag(toggleBtn, toolbar);

    toolbar.append(runBtn, toggleBtn);
    document.body.appendChild(toolbar);
    syncDockPosition();
  }

  function ensurePanel() {
    if (document.getElementById(IDS.panel)) return;

    const panel = document.createElement('section');
    panel.id = IDS.panel;

    panel.innerHTML = `
      <div class="phtt-panel-header">
        <div class="phtt-title-wrap">
          <strong>PhoneTool Title</strong>
          <span>Alias to title summary</span>
        </div>
        <button type="button" id="phtt-panel-toggle">Show</button>
      </div>
      <div id="${IDS.panelBody}">
        <div id="${IDS.panelStatus}"></div>
        <div id="${IDS.panelRows}"></div>
      </div>
    `;

    panel.querySelector('#phtt-panel-toggle').addEventListener('click', () => {
      state.collapsed = !state.collapsed;
      renderPanel();
      syncDockPosition();
    });

    document.body.appendChild(panel);
  }

  function renderPanel(statusMessage) {
    ensurePanel();

    const panel  = document.getElementById(IDS.panel);
    const status = document.getElementById(IDS.panelStatus);
    const rows   = document.getElementById(IDS.panelRows);
    const toggle = panel.querySelector('#phtt-panel-toggle');

    panel.dataset.collapsed = String(state.collapsed);
    panel.classList.toggle('phtt-panel-collapsed', state.collapsed);
    toggle.textContent = state.collapsed ? 'Show' : 'Hide';

    if (statusMessage) {
      status.textContent = statusMessage;
    } else if (state.running) {
      status.textContent = `Looking up ${state.aliases.length} alias${state.aliases.length === 1 ? '' : 'es'}...`;
    } else if (state.errors.length) {
      status.textContent = state.errors[state.errors.length - 1];
    } else if (state.aliases.length) {
      status.textContent = `Completed ${state.aliases.length} alias${state.aliases.length === 1 ? '' : 'es'}.`;
    } else {
      status.textContent = 'No aliases found.';
    }

    rows.replaceChildren();

    for (const alias of state.aliases) {
      const result  = state.results.get(alias);
      const row     = document.createElement('div');
      const aliasEl = document.createElement('div');
      const titleEl = document.createElement('div');

      row.className     = 'phtt-row';
      aliasEl.className = 'phtt-alias';
      titleEl.className = 'phtt-title';

      aliasEl.textContent = alias;
      if (result?.error) {
        row.classList.add('phtt-error');
        titleEl.textContent = result.error;
      } else {
        titleEl.textContent = result?.title || 'Pending...';
      }

      row.append(aliasEl, titleEl);
      rows.appendChild(row);
    }
  }

  function syncDockPosition() {
    const toolbar = document.getElementById(IDS.toolbar);
    if (!toolbar) return;
    toolbar.classList.toggle('phtt-toolbar-collapsed', state.collapsed);
  }

  function enableVerticalDockDrag(toggleButton, toolbar) {
    let dragging     = false;
    let dragStarted  = false;
    let pointerId    = null;
    let pointerOffsetY = 0;

    const clampTop = (nextTop) => {
      const minTop = 88;
      const maxTop = Math.max(minTop, window.innerHeight - 80);
      return Math.min(Math.max(nextTop, minTop), maxTop);
    };

    const moveToolbarTo = (clientY) => {
      const nextTop = clampTop(clientY - pointerOffsetY);
      toolbar.style.top    = `${nextTop}px`;
      toolbar.style.right  = '16px';
      toolbar.style.left   = 'auto';
      toolbar.style.bottom = 'auto';
      toolbar.style.transform = 'none';
      toolbar.dataset.dockedTop = String(nextTop);
    };

    toggleButton.addEventListener('pointerdown', (event) => {
      dragging       = true;
      dragStarted    = false;
      pointerId      = event.pointerId;
      pointerOffsetY = event.clientY - toolbar.getBoundingClientRect().top;
      toggleButton.setPointerCapture(pointerId);
      toggleButton.classList.add('phtt-toggle-grabbing');
    });

    toggleButton.addEventListener('pointermove', (event) => {
      if (!dragging || event.pointerId !== pointerId) return;
      const movement = Math.abs(event.clientY - (toolbar.getBoundingClientRect().top + pointerOffsetY));
      if (movement > 6) dragStarted = true;
      if (dragStarted) moveToolbarTo(event.clientY);
    });

    const finishDrag = (event) => {
      if (!dragging || event.pointerId !== pointerId) return;
      dragging = false;
      toggleButton.classList.remove('phtt-toggle-grabbing');
      try { toggleButton.releasePointerCapture(pointerId); } catch { /* ignore */ }
      if (dragStarted) event.preventDefault();
      dragStarted = false;
      pointerId   = null;
    };

    toggleButton.addEventListener('pointerup',     finishDrag);
    toggleButton.addEventListener('pointercancel', finishDrag);

    toggleButton.addEventListener('click', (event) => {
      if (dragStarted) {
        event.preventDefault();
        event.stopPropagation();
      }
    }, true);
  }

  async function runLookup() {
    if (state.running) return;

    state.running = true;
    state.errors  = [];
    state.results.clear();

    try {
      const aliases = collectAliases();
      state.aliases = aliases;

      if (!aliases.length) {
        throw new Error('No aliases found in table.');
      }

      renderPanel();

      for (const alias of aliases) {
        try {
          const title = await fetchTitleForAlias(alias);
          state.results.set(alias, { title });
        } catch (error) {
          const message = error instanceof Error ? error.message : String(error);
          state.results.set(alias, { error: message });
        }
        renderPanel();
        applyInlineResults();
      }
    } catch (error) {
      const message = error instanceof Error ? error.message : String(error);
      state.errors.push(message);
      renderPanel(message);
    } finally {
      state.running = false;
      renderPanel();
    }
  }

  // 芒鈥濃偓芒鈥濃偓 Alias collection 芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓

  function collectAliases() {
    const aliases  = [];
    const table    = findAliasTable();

    if (table) {
      const mode     = getPageMode();
      const bodyRows = Array.from(table.querySelectorAll('tr')).filter((row) => row.querySelectorAll('td').length > 0);
      for (const row of bodyRows) {
        const aliasCell = mode === 'access-requests'
          ? getAccessRequestsAliasCell(row)
          : getBaselineAliasCell(row, table);
        if (!aliasCell) continue;
        const alias = readAlias(aliasCell);
        if (alias) aliases.push(alias);
      }
    }

    return Array.from(new Set(aliases.map(normalizeAlias).filter(Boolean)));
  }

  function findAliasTable() {
    const tables = Array.from(document.querySelectorAll('table'));
    for (const table of tables) {
      const text = normalize(table.innerText);
      if (!table.querySelectorAll('tr td').length) continue;
      if (
        (text.includes('Alias') && text.includes('Name') && text.includes('Badge type')) ||
        (text.includes('Cardholder / Visitor') && text.includes('Request status') && text.includes('Provision status'))
      ) return table;
    }
    return null;
  }

  function getPageMode() {
    return window.location.pathname.includes('/access-requests') ? 'access-requests' : 'baselining';
  }

  // Baselining page: find the cell under the "Alias" column header.
  function getBaselineAliasCell(row, table) {
    const cells = Array.from(row.querySelectorAll('td'));
    if (!cells.length) return null;

    const headers    = Array.from(table.querySelectorAll('th, [role="columnheader"]'));
    const aliasIndex = headers.findIndex((h) => normalize(h.textContent).toLowerCase().startsWith('alias'));
    if (aliasIndex >= 0 && cells[aliasIndex]) return cells[aliasIndex];

    // Fallback: first cell.
    return cells[0];
  }

  // Access-requests page: find the cell under "Cardholder / Visitor".
  function getAccessRequestsAliasCell(row) {
    const cells = Array.from(row.querySelectorAll('td'));
    if (!cells.length) return null;

    const headers     = Array.from(document.querySelectorAll('th, [role="columnheader"]'));
    const headerIndex = headers.findIndex((header) => normalize(header.textContent) === 'Cardholder / Visitor');
    if (headerIndex >= 0 && cells[headerIndex]) return cells[headerIndex];

    for (const cell of cells) {
      if (cell.querySelector('a[href*="/users/"]')) return cell;
    }

    return cells[0];
  }

  function readAlias(aliasCell) {
    const link = aliasCell.querySelector('a[href*="/users/"]');
    if (link) {
      const match = (link.getAttribute('href') || '').match(/\/users\/([^/?#]+)/i);
      if (match) return normalizeAlias(match[1]);
    }

    const text = normalize(aliasCell.textContent);
    if (!text || text.toLowerCase().includes('no baseline assignments')) return '';

    // Alias cells often show values like "khadkatu@" in Optics.
    return normalizeAlias(text);
  }

  // 芒鈥濃偓芒鈥濃偓 PhoneTool fetch + parse 芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓

  async function fetchTitleForAlias(alias) {
    const url  = `${PHONE_TOOL_ORIGIN}/users/${encodeURIComponent(alias)}`;
    const html = await requestText(url);

    if (/proceed to midway authentication|amazon enterprise access|\/sso\/login/i.test(html)) {
      throw new Error('Phone Tool auth required');
    }

    const title = parseTitleFromUserPage(html);
    if (!title) throw new Error('Title not found');
    return title;
  }

  function parseTitleFromUserPage(html) {
    // PhoneTool embeds profile data as HTML-entity-encoded JSON in the page.
    // Raw HTTP response contains: &quot;targetUserJobTitle&quot;:&quot;Delivery Associate (OSP)&quot;
    const encodedMatch = html.match(/&quot;targetUserJobTitle&quot;\s*:\s*&quot;([^&"]+)&quot;/);
    if (encodedMatch && encodedMatch[1]) return normalize(encodedMatch[1]);

    // Fallback: decoded JSON (in case entity encoding differs).
    const jsonMatch = html.match(/"targetUserJobTitle"\s*:\s*"([^"]+)"/);
    if (jsonMatch && jsonMatch[1]) return normalize(jsonMatch[1]);

    return '';
  }

  // 芒鈥濃偓芒鈥濃偓 Inline chips 芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓芒鈥濃偓

  function applyInlineResults() {
    const table = findAliasTable();
    if (!table) return;

    const mode     = getPageMode();
    const bodyRows = Array.from(table.querySelectorAll('tr')).filter((row) => row.querySelectorAll('td').length > 0);

    for (const row of bodyRows) {
      const aliasCell = mode === 'access-requests'
        ? getAccessRequestsAliasCell(row)
        : getBaselineAliasCell(row, table);
      if (!aliasCell) continue;

      const alias = readAlias(aliasCell);
      if (!alias) continue;

      const result = state.results.get(alias);
      if (!result) continue;

      aliasCell.querySelector('.phtt-inline-chip')?.remove();

      const chip = document.createElement('span');
      chip.className = 'phtt-inline-chip';
      if (result.error) {
        chip.classList.add('phtt-inline-error');
        chip.textContent = 'Title not found';
      } else {
        chip.textContent = result.title;
      }
      aliasCell.prepend(chip);
    }
  }

