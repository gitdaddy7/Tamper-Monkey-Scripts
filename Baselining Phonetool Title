  function requestText(url) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method: 'GET', url,
        responseType: 'text', withCredentials: true, timeout: 15000,
        onload: (response) => {
          if (response.status >= 200 && response.status < 300) {
            resolve(response.responseText || '');
            return;
          }
          reject(new Error(`Request failed (${response.status})`));
        },
        onerror:   () => reject(new Error('Network error')),
        ontimeout: () => reject(new Error('Request timed out')),
      });
    });
  }

  function normalizeAlias(value) {
    const text = normalize(value).split(' ')[0];
    if (!text) return '';
    const noDomain = text.includes('@') ? text.split('@')[0] : text;
    return noDomain.replace(/[^a-zA-Z0-9._-]/g, '').toLowerCase();
  }

  function normalize(value) {
    return String(value || '').replace(/\s+/g, ' ').trim();
  }

